# 服务名称（用于健康检查展示）
SERVICE_NAME=public-japan-travel-ai

# 你的模型服务配置（以下三项最重要）
MODEL_PROVIDER=openai-compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
MODEL_NAME=gpt-4o-mini

# 模型生成参数
MODEL_TEMPERATURE=0.4
MODEL_MAX_TOKENS=3000
REQUEST_TIMEOUT=60
STREAM_TIMEOUT=90

# CORS：本地开发 / 线上前端域名，多个用逗号分隔
CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# 某些供应商需要额外 Header（例如 OpenRouter 的 HTTP-Referer / X-Title）
# 不需要时保持 {}
OPENAI_EXTRA_HEADERS={}
