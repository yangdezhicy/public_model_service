# LangChain + SiliconFlow 在线模型模式：不再占用本机 CPU / 内存跑 Ollama
SERVICE_NAME=japan-travel-ai
MODEL_PROVIDER=siliconflow
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# 请在服务器 .env 中替换为 SiliconFlow 控制台生成的真实 sk- 开头密钥；不要保留中文占位符，也不要提交真实密钥
OPENAI_API_KEY=your_siliconflow_api_key_here
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# 模型生成参数：线上模型可以适当保留更高输出上限；如额度紧张可下调到 500
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=900
MAX_CONCURRENT_REQUESTS=2
REQUEST_TIMEOUT=120

# 服务监听：容器内部监听 0.0.0.0:8000；docker-compose 将宿主机 127.0.0.1:15326 映射到容器 8000
# Nginx 对外使用 https://www.yangdezhi.com.cn/api 反向代理到 http://127.0.0.1:15326
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGINS=https://www.yangdezhi.com.cn
