# 完全免费模式：默认使用本地 Ollama 开源模型，不需要 OPENAI_API_KEY
# 4 核 CPU / 4GB 内存 / 40GB 系统盘推荐配置：默认使用 1.5B 模型提升准确性，若内存吃紧可降回 qwen2.5:0.5b
SERVICE_NAME=free-japan-travel-ai
MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
MODEL_NAME=qwen2.5:1.5b

# 模型生成参数：低温度减少幻觉；4GB 机器建议单并发，若 OOM 可把上下文降到 2048
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=1000
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_THREAD=3
MAX_CONCURRENT_REQUESTS=1
REQUEST_TIMEOUT=120
STREAM_TIMEOUT=180

# 服务监听：容器内部监听 0.0.0.0:8000；docker-compose 将宿主机 127.0.0.1:15326 映射到容器 8000
# Nginx 对外监听 15325，并 proxy_pass 到 http://127.0.0.1:15326
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGINS=*

# 可选备用：如果以后切回 OpenAI-compatible，再填写下面三项，并把 MODEL_PROVIDER 改成 openai-compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_EXTRA_HEADERS={}
