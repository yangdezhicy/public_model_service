# 完全免费模式：默认使用本地 Ollama 开源模型，不需要 OPENAI_API_KEY
SERVICE_NAME=free-japan-travel-ai
MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
MODEL_NAME=qwen2.5:1.5b

# 模型生成参数
MODEL_TEMPERATURE=0.4
MODEL_MAX_TOKENS=2000
REQUEST_TIMEOUT=120
STREAM_TIMEOUT=180

# 服务端口：你的服务器对外端口是 115.159.221.212:1217
PORT=8000
CORS_ALLOW_ORIGINS=*

# 可选备用：如果以后切回 OpenAI-compatible，再填写下面三项，并把 MODEL_PROVIDER 改成 openai-compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_EXTRA_HEADERS={}
