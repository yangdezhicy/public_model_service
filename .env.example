# 完全免费模式：默认使用本地 Ollama 开源模型，不需要 OPENAI_API_KEY
# 4 核 CPU / 4GB 内存 / 40GB 系统盘推荐配置：优先保证能稳定运行，再按需升级模型
SERVICE_NAME=free-japan-travel-ai
MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
MODEL_NAME=qwen2.5:0.5b

# 模型生成参数：低内存场景建议保持较小上下文、较短输出、单并发
MODEL_TEMPERATURE=0.35
MODEL_MAX_TOKENS=800
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_THREAD=3
MAX_CONCURRENT_REQUESTS=1
REQUEST_TIMEOUT=120
STREAM_TIMEOUT=180

# 服务端口：你的服务器对外端口是 115.159.221.212:8888
PORT=8000
CORS_ALLOW_ORIGINS=*

# 可选备用：如果以后切回 OpenAI-compatible，再填写下面三项，并把 MODEL_PROVIDER 改成 openai-compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_EXTRA_HEADERS={}
